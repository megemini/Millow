// Re-export the `millow` public API so the alignment suite below can call it
// unqualified. These tests verify millow's output against expected bytes
// generated by Python (skimage / Pillow / numpy) — see generate_fixtures.py.

///|
pub using @millow {
  type Image,
  type Interp,
  type Kernel,
  type PadMode,
  type PpmEncoder,

  // Channels & color
  to_grayscale,
  to_bgr,
  invert,
  tint,
  flatten_alpha,
  composite_over,
  merge_channels,

  // Geometry
  crop,
  flip_horizontal,
  flip_vertical,
  rotate_90,
  rotate_180,
  rotate_270,
  rotate_any,
  affine_transform,
  translate,
  shear,
  resize,
  rescale,
  pad,
  pad_to_size,

  // Enhancement & tone
  adjust_brightness,
  adjust_contrast,
  adjust_gamma,
  normalize,
  auto_contrast,
  sharpen,
  unsharp_mask,

  // Threshold & histogram
  threshold,
  threshold_inv,
  threshold_otsu,
  histogram,
  histogram_color,
  equalize_histogram,

  // Filters
  convolve,
  box_blur,
  gaussian_blur,
  gaussian_blur_kernel,
  median_filter,
  min_filter,
  max_filter,
  bilateral_filter,

  // Edges
  sobel,
  sobel_x,
  sobel_y,
  scharr,
  prewitt,
  laplacian,

  // Morphology
  erode,
  dilate,
  morph_open,
  morph_close,
  morph_gradient,
  top_hat,
  black_hat,

  // Drawing
  draw_pixel,
  draw_line,
  draw_rect,
  draw_circle,

  // Feature detection
  corner_harris,
  corner_shi_tomasi,
  hog,
  lbp,
  lbp_histogram,

  // Measurement
  connected_components,
  find_contours,
  regionprops,
  count_nonzero,
  count_pixels,
  moments,
  hu_moments,

  // Metrics & inspection
  info,
  equals,
  mse,
  psnr,

  // Serialization
  to_ppm,
  to_pgm,
  to_display_bytes,

  // Numeric helpers
  clampi,
  clampd,
  clamp_byte,
  round_byte,
}
