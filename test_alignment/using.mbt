// Re-export the `millow` public API so the alignment suite below can call it
// unqualified. These tests verify millow's output against expected bytes
// generated by Python (skimage / Pillow / numpy) — see generate_fixtures.py.

///|
pub using @millow {
  type Image,
  type Interp,
  type Kernel,
  type PadMode,
  type PpmEncoder,
  type LineDirection,

  // Channels & color
  to_grayscale,
  to_bgr,
  invert,
  tint,
  flatten_alpha,
  composite_over,
  merge_channels,

  // Geometry
  crop,
  auto_crop,
  flip_horizontal,
  flip_vertical,
  rotate_90,
  rotate_180,
  rotate_270,
  rotate_any,
  affine_transform,
  translate,
  shear,
  resize,
  rescale,
  pad,
  pad_to_size,
  skew_angle,
  deskew,
  perspective_transform,
  perspective_4pt,
  resize_to_model_input,
  letterbox,

  // Enhancement & tone
  adjust_brightness,
  adjust_contrast,
  adjust_gamma,
  normalize,
  auto_contrast,
  sharpen,
  unsharp_mask,

  // Threshold & histogram
  threshold,
  threshold_inv,
  threshold_otsu,
  threshold_sauvola,
  threshold_niblack,
  threshold_bernsen,
  threshold_wolf,
  adaptive_threshold_mean,
  adaptive_threshold_gaussian,
  histogram,
  histogram_color,
  equalize_histogram,

  // Filters
  convolve,
  box_blur,
  gaussian_blur,
  gaussian_blur_kernel,
  median_filter,
  min_filter,
  max_filter,
  bilateral_filter,
  guided_filter,
  guided_filter_self,
  wiener_filter,
  dog,

  // Edges
  sobel,
  sobel_x,
  sobel_y,
  scharr,
  prewitt,
  laplacian,

  // Morphology
  erode,
  dilate,
  morph_open,
  morph_close,
  morph_gradient,
  top_hat,
  black_hat,
  remove_small_objects,
  remove_small_holes,
  remove_lines,

  // Drawing
  draw_pixel,
  draw_line,
  draw_rect,
  draw_circle,

  // Feature detection
  corner_harris,
  corner_shi_tomasi,
  hog,
  lbp,
  lbp_histogram,

  // Measurement
  connected_components,
  find_contours,
  regionprops,
  count_nonzero,
  count_pixels,
  moments,
  hu_moments,
  project_horizontal,
  project_vertical,
  project_horizontal_binary,
  project_vertical_binary,
  integral_image,
  integral_array,
  integral_image_sq,
  integral_array_sq,
  query_integral,
  hough_lines,
  distance_transform,
  template_match,
  template_match_best,
  kmeans_quantize,

  // Metrics & inspection
  info,
  equals,
  mse,
  psnr,
  ssim,

  // Serialization
  to_ppm,
  to_pgm,
  to_display_bytes,

  // Numeric helpers
  clampi,
  clampd,
  clamp_byte,
  round_byte,
}
